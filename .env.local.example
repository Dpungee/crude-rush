# ─── Supabase ─��───────────────────────────────���──────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Browser-side Supabase client (unused currently, all access via server)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: PgBouncer connection pooler URL (recommended for production >200 concurrent)
# SUPABASE_DB_POOLER_URL=postgresql://...pooler.supabase.com:6543/postgres

# ─── JWT ─────────���───────────────────────��───────────────────────────────────
# REQUIRED in production. Must be ≥32 characters.
# In dev, an ephemeral random secret is auto-generated if this is not set.
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# ─── Solana ────────────────────────────────────���─────────────────────────────
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Optional: Paid RPC endpoint for reliability (recommended for production)
# SOLANA_RPC_URL=https://your-rpc-provider.com
# NEXT_PUBLIC_SOLANA_RPC_URL=https://your-rpc-provider.com

# ─── Token (set after TGE) ───────────────────────────────────────────────────
# NEXT_PUBLIC_CRUDE_TOKEN_MINT=your-token-mint-address
# NEXT_PUBLIC_STAKING_PROGRAM_ID=your-staking-program-id
# TREASURY_KEYPAIR_SECRET=base58-encoded-treasury-keypair

# ─── NFT Land Deeds (set after collection deploy) ────────────────────────────
# NFT_LAND_DEED_COLLECTION=your-collection-mint-address
